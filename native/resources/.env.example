# fleet-agent-mcp (Fritz) — environment configuration
# Copy to .env and fill in your values.
# All vars are prefixed with FLEET_AGENT_ (see config.py).

# Server
# FLEET_AGENT_HOST=127.0.0.1
# FLEET_AGENT_PORT=10996
# FLEET_AGENT_TRANSPORT=http

# Agent identity
# FLEET_AGENT_AGENT_NAME=Fritz
# FLEET_AGENT_HUMAN_NAME=Sandra

# Heartbeat (cron-based autonomous wake-up)
# FLEET_AGENT_HEARTBEAT_ENABLED=false
# FLEET_AGENT_HEARTBEAT_INTERVAL_MINUTES=30
